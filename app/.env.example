# ===== BrewGuard 环境变量配置 =====
# 复制此文件为 app/.env 并填入真实值

# --- 安全 ---
# 生成方式: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-hex-string
DEBUG=true

# --- 数据库 ---
# 开发环境默认 SQLite(无需配置),生产环境取消注释:
# DATABASE_URL=mysql://user:password@localhost:3306/brewguard
# DATABASE_URL=postgres://user:password@localhost:5432/brewguard

# --- CORS 白名单(逗号分隔) ---
# 生产环境改为你的域名,如: https://brew.example.com
# CORS_ORIGINS=https://brew.example.com

# --- AI 助手(DeepSeek) ---
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- JWT ---
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
